# ============================================================
# Paperclip Multi-Agent Environment Configuration
# Supports: MiniMax Token Plan + GLM Coding Plan (Z.AI)
# ============================================================

# ===== REQUIRED SECRET KEYS =====
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-hex-32

# PostgreSQL password
POSTGRES_PASSWORD=paperclip_change_me_in_production

# Public URL (change to your server URL in production)
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# ===== MINIMAX TOKEN PLAN (Claude Code + OpenClaw) =====
# Get from: https://platform.minimax.io/user-center/payment/token-plan
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_ANTHROPIC_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# ===== GLM CODING PLAN (Z.AI) (Hermes Agent) =====
# Get from: https://z.ai/model-api (API keys at https://z.ai/manage-apikey/apikey-list)
GLM_API_KEY=your_glm_api_key_here
GLM_ANTHROPIC_URL=https://api.z.ai/api/anthropic
GLM_MODEL=GLM-4.7

# ===== OPTIONAL AGENT API KEYS =====
# For Codex and other adapters
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ===== APPLICATION SETTINGS =====
PAPERCLIP_PORT=3100

# Agent resource limits
CLAUDE_CPU=1.5
CLAUDE_MEM=3G
HERMES_CPU=1
HERMES_MEM=2G
OPENCLAW_CPU=1
OPENCLAW_MEM=2G

# Backup
BACKUP_DIR=./backups