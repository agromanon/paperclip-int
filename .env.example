# ============================================================
# Paperclip Multi-Agent Environment Configuration
# Supports: MiniMax Token Plan + GLM Coding Plan (Z.AI)
# ============================================================

# ===== MINIMAX TOKEN PLAN (Claude Code) =====
# Get from: https://platform.minimax.io/user-center/payment/token-plan
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_ANTHROPIC_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# ===== GLM CODING PLAN (Z.AI) =====
# Get from: https://z.ai/model-api (API keys at https://z.ai/manage-apikey/apikey-list)
GLM_API_KEY=your_glm_api_key_here
GLM_ANTHROPIC_URL=https://api.z.ai/api/anthropic
GLM_MODEL=GLM-4.7

# Which agent uses which plan:
# - Claude Agent: MINIMAX_API_KEY (MiniMax Token Plan)
# - Hermes Agent: GLM_API_KEY (GLM Coding Plan)
# - OpenClaw: MINIMAX_API_KEY (MiniMax Token Plan)

# ===== APPLICATION SETTINGS =====
PAPERCLIP_VERSION=latest
PAPERCLIP_PORT=3100

# Agent resource limits
CLAUDE_CPU=1.5
CLAUDE_MEM=3G
HERMES_CPU=1
HERMES_MEM=2G
OPENCLAW_CPU=1
OPENCLAW_MEM=2G

# Network
NETWORK_SUBNET=10.20.0.0/24

# Backup
BACKUP_DIR=./backups